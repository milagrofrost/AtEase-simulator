{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AtEase",
  "version": "0.1.0",
  "identifier": "org.atease.launcher",
  "build": {
    "beforeDevCommand": "npm run vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run typecheck && npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AtEase",
        "fullscreen": true,
        "resizable": false,
        "decorations": false,
        "width": 640,
        "height": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": ["icons/icon.png"]
  }
}
