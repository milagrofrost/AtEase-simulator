{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AtEase",
  "version": "0.1.0",
  "identifier": "org.atease.launcher",
  "build": {
    "beforeDevCommand": "npm run vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run typecheck && npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AtEase",
        "visible": false,
        "fullscreen": false,
        "resizable": false,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnBottom": true,
        "width": 673,
        "height": 480,
        "x": 71,
        "y": 0
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.local/share/atease/cache/icons/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": ["icons/icon.png"],
    "resources": {
      "../src/assets/sounds/click.wav": "sounds/click.wav"
    }
  }
}
